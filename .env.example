# URL pública del sitio (para metadataBase / Open Graph). Opcional en local.
# Debe incluir protocolo: https://... Si está vacía o es inválida, el sitio usa una URL por defecto.
# Producción (Vercel → Environment Variables):
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app
# Local (opcional):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
